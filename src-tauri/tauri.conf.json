{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "glassout-client",
  "version": "0.1.0",
  "identifier": "com.markthorburn.glassout-client",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "launcher",
        "title": "GlassOut Launcher",
        "url": "launcher.html",
        "width": 560,
        "height": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
