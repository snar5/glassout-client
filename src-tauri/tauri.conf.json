{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "glassout-client",
  "version": "0.1.0",
  "identifier": "com.markthorburn.glassout-client",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "PFD / MFD",
        "url": "index.html",
        "width": 1200,
        "height": 700,
        "x": 0,
        "y": 0
      },
      {
        "label": "eic",
        "title": "EIC",
        "url": "eic.html",
        "width": 800,
        "height": 500,
        "x": 1220,
        "y": 0
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
